# llama-swap-optimizer configuration
# Copy this file to .env and edit paths to match your environment.

# Path to directory containing llama-bench (required)
LLAMA_BIN=path/to/llama-server

# Path to llama-swap config.yaml (required)
CONFIG_YAML=path/to/llama-swap/config.yaml

# Directory to save per-model optimization results (optional, default: ./results/)
# RESULTS_DIR=./results

# Optimization defaults (optional)
# DEFAULT_TRIALS=30
# DEFAULT_REPEAT=2
# DEFAULT_METRIC=tg
# DEFAULT_TIMEOUT=21600

# Overwrite config.yaml in place instead of generating config-optimized.yaml
# A timestamped backup is always created before overwriting.
# DEFAULT_OVERWRITE=true
